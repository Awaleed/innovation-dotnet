# ───────────────────────────────────────────
# Groups (groupOfNames requires at least one member)
# ───────────────────────────────────────────

dn: cn=admin,ou=groups,dc=company,dc=local
objectClass: groupOfNames
cn: admin
member: cn=admin@alinmabank.test,ou=users,dc=company,dc=local

dn: cn=user,ou=groups,dc=company,dc=local
objectClass: groupOfNames
cn: user
member: cn=admin@alinmabank.test,ou=users,dc=company,dc=local
member: cn=demo@innovation.test,ou=users,dc=company,dc=local
member: cn=jdoe,ou=users,dc=company,dc=local
