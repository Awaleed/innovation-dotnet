# Organizational Units
dn: ou=users,dc=company,dc=local
objectClass: organizationalUnit
ou: users

dn: ou=groups,dc=company,dc=local
objectClass: organizationalUnit
ou: groups

# ───────────────────────────────────────────
# Users
# ───────────────────────────────────────────

# Admin user (matches Keycloak realm: admin@alinmabank.test / Admin@123!)
dn: cn=admin@alinmabank.test,ou=users,dc=company,dc=local
objectClass: inetOrgPerson
cn: admin@alinmabank.test
sn: Admin
givenName: Super Admin
mail: admin@alinmabank.test
userPassword: Admin@123!

# Demo user (matches Keycloak realm: demo@innovation.test / Demo@123!)
dn: cn=demo@innovation.test,ou=users,dc=company,dc=local
objectClass: inetOrgPerson
cn: demo@innovation.test
sn: User
givenName: Demo
mail: demo@innovation.test
userPassword: Demo@123!

