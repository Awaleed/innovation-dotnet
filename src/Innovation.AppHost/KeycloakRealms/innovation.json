{
  "realm": "innovation",
  "enabled": true,
  "registrationAllowed": false,
  "resetPasswordAllowed": true,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "sslRequired": "none",
  "passwordPolicy": "length(8) and upperCase(1) and lowerCase(1) and digits(1) and specialChars(1)",
  "requiredActions": [
    { "alias": "VERIFY_EMAIL", "name": "Verify Email", "enabled": false, "defaultAction": false },
    { "alias": "UPDATE_PASSWORD", "name": "Update Password", "enabled": false, "defaultAction": false },
    { "alias": "UPDATE_PROFILE", "name": "Update Profile", "enabled": false, "defaultAction": false },
    { "alias": "CONFIGURE_TOTP", "name": "Configure OTP", "enabled": false, "defaultAction": false },
    { "alias": "terms_and_conditions", "name": "Terms and Conditions", "enabled": false, "defaultAction": false }
  ],
  "roles": {
    "realm": [
      { "name": "admin", "description": "Administrator" },
      { "name": "user", "description": "Standard user" }
    ]
  },
  "defaultRoles": ["user"],
  "clients": [
    {
      "clientId": "innovation-web",
      "name": "Innovation Web",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "innovation-web-secret",
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "publicClient": false,
      "protocol": "openid-connect",
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "attributes": {
        "post.logout.redirect.uris": "*"
      },
      "protocolMappers": [
        {
          "name": "name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "firstName",
            "claim.name": "name",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "claim.name": "roles",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "service-account-innovation-web",
      "enabled": true,
      "serviceAccountClientId": "innovation-web",
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "view-users"
        ]
      }
    },
    {
      "username": "admin@alinmabank.test",
      "email": "admin@alinmabank.test",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Super Admin",
      "lastName": "",
      "realmRoles": ["admin", "user"],
      "credentials": [
        {
          "type": "password",
          "value": "Admin@123!",
          "temporary": false
        }
      ]
    },
    {
      "username": "demo@innovation.test",
      "email": "demo@innovation.test",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Demo User",
      "lastName": "",
      "realmRoles": ["user"],
      "credentials": [
        {
          "type": "password",
          "value": "Demo@123!",
          "temporary": false
        }
      ]
    }
  ]
}
